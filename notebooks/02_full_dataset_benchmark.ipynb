import numpy as np
import json
from pathlib import Path
from sklearn.metrics import (
    average_precision_score, precision_recall_curve,
    roc_auc_score, confusion_matrix
)
import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt

OUT = Path("poc_results"); OUT.mkdir(exist_ok=True)

print("="*65)
print("  COST-SENSITIVE EVALUATION — CORRECT METRICS FOR BIOSECURITY")
print("="*65)
print(f"\n  Class distribution:")
print(f"    Threat: {is_threat.sum():,}  ({is_threat.mean():.1%})")
print(f"    Benign: {(is_threat==0).sum():,}  ({(1-is_threat).mean():.1%})")
print(f"\n  Note: AUROC is reported for reference only.")
print(f"  Primary metrics: AP, Recall@FPR, FNR@threshold\n")

# ── 1. Average Precision (PR-AUC) ────────────────────────────────
ap = average_precision_score(is_threat, sev)
auroc = roc_auc_score(is_threat, sev)
print(f"  AUROC (reference only):    {auroc:.4f}")
print(f"  Average Precision (AP):    {ap:.4f}  ← primary metric")
print(f"  Baseline AP (random):      {is_threat.mean():.4f}")
print(f"  AP lift over baseline:     {ap/is_threat.mean():.1f}x\n")

# ── 2. Recall at fixed FPR thresholds ────────────────────────────
print(f"  RECALL AT FIXED FALSE POSITIVE RATES")
print(f"  (how many threats caught at each FPR budget)")
print(f"  {'FPR budget':12}  {'Recall':>8}  {'Threshold':>10}  "
      f"{'Flags/1000':>12}  {'Missed threats':>15}")
print(f"  {'─'*65}")

prec, rec, thresh = precision_recall_curve(is_threat, sev)
# Also get ROC for recall@FPR
from sklearn.metrics import roc_curve
fpr_arr, tpr_arr, thresh_roc = roc_curve(is_threat, sev)

for target_fpr in [0.001, 0.005, 0.01, 0.02, 0.05, 0.10]:
    # Find threshold that gives this FPR
    idx = np.searchsorted(fpr_arr, target_fpr)
    if idx >= len(thresh_roc): idx = len(thresh_roc)-1
    t = thresh_roc[idx]
    recall_at = tpr_arr[idx]
    fnr = 1 - recall_at
    # How many benign sequences flagged per 1000
    flags_per_1000 = target_fpr * 1000
    missed = fnr * is_threat.sum()
    print(f"  FPR ≤ {target_fpr:.1%}:      {recall_at:>8.3f}  "
          f"{t:>10.3f}  {flags_per_1000:>12.1f}  {missed:>15.0f}")

# ── 3. Cost-sensitive threshold analysis ─────────────────────────
print(f"\n  COST-SENSITIVE THRESHOLD ANALYSIS")
print(f"  Assuming: missing a threat costs 1000x flagging a benign")
print(f"  Cost = FN_count × 1000 + FP_count × 1")
print(f"  {'Threshold':10}  {'FN':>8}  {'FP':>8}  "
      f"{'FNR':>6}  {'FPR':>6}  {'Cost':>12}")
print(f"  {'─'*60}")

best_cost, best_thresh = float("inf"), 0
for t in np.arange(0.1, 1.0, 0.05):
    pred = (sev >= t).astype(int)
    tn, fp, fn, tp = confusion_matrix(is_threat, pred).ravel()
    fnr = fn / (fn + tp + 1e-8)
    fpr = fp / (fp + tn + 1e-8)
    cost = fn * 1000 + fp * 1
    if cost < best_cost:
        best_cost = cost
        best_thresh = t
    print(f"  t={t:.2f}:     {fn:>8,}  {fp:>8,}  "
          f"{fnr:>6.3f}  {fpr:>6.3f}  {cost:>12,.0f}")

print(f"\n  ★ Optimal threshold: {best_thresh:.2f}  "
      f"(cost={best_cost:,.0f})")

# ── 4. Short-sequence cost-sensitive ─────────────────────────────
print(f"\n  SHORT-SEQUENCE: RECALL@FPR≤1% BY LENGTH BIN")
print(f"  {'Length':10}  {'N threat':>9}  {'N benign':>9}  "
      f"{'AP':>7}  {'Recall@1%FPR':>13}  {'FNR@1%FPR':>10}")
print(f"  {'─'*65}")

for lo, hi in [(30,50),(50,75),(75,100),(100,150),
               (150,200),(200,300),(300,500)]:
    mask_len = (lens >= lo) & (lens < hi)
    t_mask   = mask_len & (is_threat == 1)
    b_mask   = mask_len & (is_threat == 0)
    if t_mask.sum() < 10 or b_mask.sum() < 10:
        continue
    y_true = np.concatenate([np.ones(t_mask.sum()),  np.zeros(b_mask.sum())])
    y_score= np.concatenate([sev[t_mask], sev[b_mask]])
    ap_bin = average_precision_score(y_true, y_score)

    # Recall at 1% FPR
    fpr_b, tpr_b, _ = roc_curve(y_true, y_score)
    idx = np.searchsorted(fpr_b, 0.01)
    if idx >= len(tpr_b): idx = len(tpr_b)-1
    recall_1pct = tpr_b[idx]
    fnr_1pct    = 1 - recall_1pct

    flag = "✓" if recall_1pct > 0.80 else "~" if recall_1pct > 0.60 else "✗"
    print(f"  {lo:3d}-{hi:3d}aa:  {t_mask.sum():>9,}  {b_mask.sum():>9,}  "
          f"{ap_bin:>7.4f}  {recall_1pct:>13.3f}  "
          f"{fnr_1pct:>10.3f}  {flag}")

# ── 5. PR curve plot ─────────────────────────────────────────────
fig, axes = plt.subplots(1, 3, figsize=(18, 6))
fig.patch.set_facecolor("#F8F9FA")

# PR curve
ax = axes[0]
ax.plot(rec, prec, color="#C0392B", lw=2.5, label=f"SVD Severity (AP={ap:.3f})")
ax.axhline(is_threat.mean(), color="gray", lw=1.5, linestyle="--",
           label=f"Random baseline (AP={is_threat.mean():.3f})")
ax.fill_between(rec, prec, alpha=0.15, color="#C0392B")
ax.set_xlabel("Recall (Sensitivity)", fontsize=12)
ax.set_ylabel("Precision", fontsize=12)
ax.set_title("Precision-Recall Curve\n(correct metric for imbalanced data)",
             fontweight="bold")
ax.legend(fontsize=10)
ax.set_facecolor("#FFFFFF"); ax.grid(True, alpha=0.3)
ax.annotate(f"AP = {ap:.3f}\n({ap/is_threat.mean():.0f}x baseline)",
            xy=(0.5, 0.6), fontsize=12, color="#C0392B",
            ha="center", fontweight="bold")

# Recall@FPR curve
ax = axes[1]
ax.plot(fpr_arr, tpr_arr, color="#2E86C1", lw=2.5)
ax.fill_between(fpr_arr, tpr_arr, alpha=0.15, color="#2E86C1")
for target_fpr, col in [(0.01,"#E74C3C"),(0.05,"#E67E22")]:
    idx = np.searchsorted(fpr_arr, target_fpr)
    if idx < len(tpr_arr):
        ax.axvline(target_fpr, color=col, lw=1.5, linestyle="--",
                   label=f"FPR={target_fpr:.0%} → Recall={tpr_arr[idx]:.2f}")
        ax.scatter([target_fpr],[tpr_arr[idx]], color=col, s=80, zorder=5)
ax.set_xlabel("False Positive Rate", fontsize=12)
ax.set_ylabel("Recall (True Positive Rate)", fontsize=12)
ax.set_title("ROC Curve\nRecall at operational FPR budgets",
             fontweight="bold")
ax.legend(fontsize=9); ax.set_facecolor("#FFFFFF"); ax.grid(True, alpha=0.3)
ax.set_xlim(-0.01, 0.3)  # zoom in — most action is at low FPR

# Cost surface
ax = axes[2]
thresholds = np.arange(0.05, 1.0, 0.01)
costs, fnrs, fprs = [], [], []
for t in thresholds:
    pred = (sev >= t).astype(int)
    tn, fp, fn, tp = confusion_matrix(is_threat, pred).ravel()
    costs.append(fn * 1000 + fp)
    fnrs.append(fn / (fn + tp + 1e-8))
    fprs.append(fp / (fp + tn + 1e-8))

ax2 = ax.twinx()
ax.plot(thresholds, fnrs, color="#C0392B", lw=2, label="FNR (miss rate)")
ax.plot(thresholds, fprs, color="#2E86C1", lw=2, label="FPR (false alarm)")
ax2.plot(thresholds, [c/max(costs) for c in costs],
         color="#8E44AD", lw=2.5, linestyle="--", label="Normalised cost")
ax.axvline(best_thresh, color="#27AE60", lw=2,
           label=f"Optimal t={best_thresh:.2f}")
ax.set_xlabel("Severity Threshold", fontsize=12)
ax.set_ylabel("Rate", fontsize=12)
ax2.set_ylabel("Normalised Cost (lower=better)", color="#8E44AD")
ax.set_title(f"Cost-Sensitive Threshold Selection\n"
             f"(FN cost = 1000× FP cost)",
             fontweight="bold")
lines1, labels1 = ax.get_legend_handles_labels()
lines2, labels2 = ax2.get_legend_handles_labels()
ax.legend(lines1+lines2, labels1+labels2, fontsize=8)
ax.set_facecolor("#FFFFFF"); ax.grid(True, alpha=0.3)

fig.suptitle(
    f"Geometric Biosecurity — Cost-Sensitive Evaluation\n"
    f"{len(is_threat):,} sequences | AP={ap:.3f} | "
    f"Optimal threshold={best_thresh:.2f}",
    fontsize=13, fontweight="bold"
)
plt.tight_layout()
fig.savefig(OUT/"cost_sensitive_evaluation.png", dpi=150, bbox_inches="tight")
plt.show()

print(f"\n{'='*65}")
print(f"  COMPETITION SUBMISSION METRICS")
print(f"{'='*65}")
print(f"  Primary:   Average Precision = {ap:.4f}  "
      f"({ap/is_threat.mean():.0f}x random baseline)")
print(f"  Secondary: Recall @ FPR≤1%  = ", end="")
idx1pct = np.searchsorted(fpr_arr, 0.01)
print(f"{tpr_arr[idx1pct]:.3f}  "
      f"(FNR={1-tpr_arr[idx1pct]:.3f})")
print(f"  Optimal threshold (cost-weighted): {best_thresh:.2f}")
print(f"  At optimal threshold:")
pred_opt = (sev >= best_thresh).astype(int)
tn,fp,fn,tp = confusion_matrix(is_threat, pred_opt).ravel()
print(f"    Recall (TPR):  {tp/(tp+fn):.3f}  ({tp:,} threats caught)")
print(f"    FPR:           {fp/(fp+tn):.4f}  ({fp:,} false alarms)")
print(f"    Precision:     {tp/(tp+fp):.3f}")
print(f"    Missed threats:{fn:,}  ({fn/(fn+tp):.1%} of all threats)")
print(f"{'='*65}")
