ax.axhline(0.8, color="gray", linewidth=1, linestyle="--", alpha=0.7, label="|d|=0.8 (large)")
ax.axhline(-0.8, color="gray", linewidth=1, linestyle="--", alpha=0.7)

ax.set_xlabel("SVD Component", fontsize=12)
ax.set_ylabel("Cohen's d (Threat − Benign)", fontsize=12)
ax.set_title("Class Loading Per Component (|d| > 0.8 = large effect)", fontsize=13, fontweight="bold")
ax.legend(fontsize=10)
ax.grid(True, axis="y", alpha=0.3)
plt.tight_layout()
plt.show()

n_large = sum(abs(d) > 0.8 for d in effects)
print(f"Components with |d| > 0.8: {n_large}/{len(effects)}")

# %% Cell 15: Plot 6 — Threat Axis Projection (1D)

threat_proj = Z @ analyzer.threat_axis_

fig, ax = plt.subplots(figsize=(10, 5))
for lbl_int, name, col in [(1, "Threat", TIER_COLORS["threat"]),
