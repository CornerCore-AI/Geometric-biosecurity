# %% Cell 6: ESM-2 Embedding

def embed_sequences(sequences, model_key, batch_size_override=None):
    """
    Run ESM-2 inference, return embedding matrix [N, D].
    Mean-pooled last-layer representations.
    """
    import torch
    from transformers import AutoTokenizer, AutoModel

    n_seqs = len(sequences)
    cache_tag = f"embeddings_{model_key}_{n_seqs}"
    cache_path = CACHE_DIR / f"{cache_tag}.npy"

    if cache_path.exists():
        print(f"[cache] Loading embeddings from {cache_path}")
        E = np.load(cache_path)
        if E.shape[0] == n_seqs:
            print(f"  Shape: {E.shape} ✓")
            return E
        print(f"  Shape mismatch ({E.shape[0]} vs {n_seqs}), re-embedding...")

    model_name = ESM_MODELS[model_key]
    print(f"Loading ESM-2 model: {model_name}")
    tokenizer = AutoTokenizer.from_pretrained(model_name)
    model = AutoModel.from_pretrained(model_name)

    device = "cuda" if torch.cuda.is_available() else "cpu"
    print(f"  Device: {device}")
    model = model.to(device).eval()

    # Batch size
    if batch_size_override:
        batch_size = batch_size_override
    elif device == "cuda":
        # Compatible with both old and new PyTorch versions
        props = torch.cuda.get_device_properties(0)
        # Try total_memory first (newer PyTorch), fall back to total_mem (older)
        try:
            gpu_mem_bytes = props.total_memory
        except AttributeError:
            try:
                gpu_mem_bytes = props.total_mem
            except AttributeError:
                # Last resort: query directly
                gpu_mem_bytes = torch.cuda.mem_get_info(0)[1]
        gpu_mem_gb = gpu_mem_bytes / 1e9
        print(f"  GPU memory: {gpu_mem_gb:.1f} GB")

        if "t33_650M" in model_key:
            batch_size = max(2, int(gpu_mem_gb / 5))
        elif "t30_150M" in model_key:
            batch_size = max(4, int(gpu_mem_gb / 2))
        else:
            batch_size = max(8, int(gpu_mem_gb))
    else:
        batch_size = 4

    print(f"  Embedding {n_seqs:,d} sequences (batch_size={batch_size})...")

    seqs_text = [s["seq"] for s in sequences]
    max_seq_len = max(len(s) for s in seqs_text)
    print(f"  Max sequence length: {max_seq_len} aa")

    # Incremental checkpoint
    CHECKPOINT_INTERVAL = 500
    checkpoint_path = CACHE_DIR / f"{cache_tag}_partial.npy"
    embeddings_list = []
    start_idx = 0

    if checkpoint_path.exists():
        partial = np.load(checkpoint_path)
        n_done = partial.shape[0]
        if n_done < n_seqs:
            print(f"  [resume] Partial checkpoint: {n_done:,d}/{n_seqs:,d}")
            embeddings_list.append(partial)
            start_idx = n_done
        else:
            np.save(cache_path, partial)
            checkpoint_path.unlink()
            print(f"  Shape: {partial.shape} ✓")
            return partial

    total_batches = (n_seqs - start_idx - 1) // batch_size + 1
    t_start = time.time()

    for batch_num, i in enumerate(range(start_idx, n_seqs, batch_size)):
        batch = seqs_text[i : i + batch_size]
        t0 = time.time()

        inputs = tokenizer(
            batch,
            return_tensors="pt",
            padding=True,
            truncation=True,
            max_length=min(max_seq_len + 2, 1024),
        ).to(device)

        with torch.no_grad():
            outputs = model(**inputs)

        hidden = outputs.last_hidden_state
        attention_mask = inputs["attention_mask"].unsqueeze(-1).float()
        seq_lengths = attention_mask.sum(dim=1)
        summed = (hidden * attention_mask).sum(dim=1)
        mean_pooled = summed / seq_lengths

        embeddings_list.append(mean_pooled.cpu().numpy())

        elapsed = time.time() - t0
        total_done = i + len(batch)
        overall_elapsed = time.time() - t_start
        rate = (total_done - start_idx) / overall_elapsed if overall_elapsed > 0 else 0
        eta = (n_seqs - total_done) / rate if rate > 0 else 0

        # Progress every 100 batches or at the end
        if (batch_num + 1) % 100 == 0 or (batch_num + 1) == total_batches:
            pct = total_done / n_seqs * 100
            print(f"  [{pct:5.1f}%] {total_done:,d}/{n_seqs:,d} | "
                  f"{rate:.0f} seqs/s | ETA {eta/60:.1f}min")

        # Periodic checkpoint
        if (batch_num + 1) % CHECKPOINT_INTERVAL == 0:
            partial = np.vstack(embeddings_list)
            np.save(checkpoint_path, partial)

        if device == "cuda" and (batch_num + 1) % 200 == 0:
            torch.cuda.empty_cache()

    E = np.vstack(embeddings_list)
    np.save(cache_path, E)
    total_time = time.time() - t_start
    print(f"  ✓ Embedding matrix: {E.shape}")
    print(f"  ✓ Total time: {total_time/60:.1f} min ({total_time/n_seqs:.3f} s/seq)")

    if checkpoint_path.exists():
        checkpoint_path.unlink()

    return E


E = embed_sequences(sequences, model_key=MODEL_KEY,
                    batch_size_override=BATCH_SIZE_OVERRIDE)



