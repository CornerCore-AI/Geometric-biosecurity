# %% Cell 4: Load Dataset

def load_dataset(dataset_path, max_per_class=None, max_total=None, seed=42):
    """
    Load the pre-built dataset_full.json (~179k sequences).
    """
    print(f"Loading dataset from {dataset_path}")
    if not dataset_path.exists():
        raise FileNotFoundError(
            f"Dataset not found at {dataset_path}.\n"
            f"Please ensure dataset_full.json is in {CACHE_DIR.resolve()}/"
        )

    raw = json.loads(dataset_path.read_text())
    print(f"  Raw entries loaded: {len(raw):,}")

    # Validate and annotate
    valid = []
    skipped_labels = Counter()
    for entry in raw:
        label = entry.get("label", "")
        if label not in THREAT_TIERS:
            skipped_labels[label] += 1
            continue
        tier_info = THREAT_TIERS[label]
        entry["tier"] = tier_info["tier"]
        entry["label_int"] = tier_info["label_int"]
        entry["is_threat"] = tier_info["is_threat"]
        if not entry.get("seq"):
            continue
        valid.append(entry)

    if skipped_labels:
        print(f"  Skipped unknown labels: {dict(skipped_labels)}")

    # Report
    class_counts = Counter(e["label"] for e in valid)
    print(f"\n  {'CLASS':<28s} {'COUNT':>8s}")
    print("  " + "─" * 38)
    for cls in sorted(class_counts.keys()):
        print(f"  {cls:<28s} {class_counts[cls]:>8,d}")
    print("  " + "─" * 38)
    print(f"  {'TOTAL':<28s} {len(valid):>8,d}")

    threat_count = sum(1 for e in valid if e["is_threat"] == 1)
    benign_count = sum(1 for e in valid if e["is_threat"] == 0)
    print(f"\n  Threat (toxin+virus): {threat_count:,d}")
    print(f"  Benign:              {benign_count:,d}")

    # Subsampling
    rng = np.random.RandomState(seed)

    if max_per_class is not None:
        print(f"\n  Subsampling: max {max_per_class:,d} per raw class...")
        by_class = {}
        for e in valid:
            by_class.setdefault(e["label"], []).append(e)
        subsampled = []
        for cls, entries in by_class.items():
            if len(entries) > max_per_class:
                idx = rng.choice(len(entries), max_per_class, replace=False)
                entries = [entries[i] for i in idx]
            subsampled.extend(entries)
        valid = subsampled
        rng.shuffle(valid)

    if max_total is not None and len(valid) > max_total:
        print(f"  Subsampling: max {max_total:,d} total (stratified)...")
        threats = [e for e in valid if e["is_threat"] == 1]
        benigns = [e for e in valid if e["is_threat"] == 0]
        ratio = len(threats) / len(valid)
        n_threat = int(max_total * ratio)
        n_benign = max_total - n_threat
        if len(threats) > n_threat:
            idx = rng.choice(len(threats), n_threat, replace=False)
            threats = [threats[i] for i in idx]
        if len(benigns) > n_benign:
            idx = rng.choice(len(benigns), n_benign, replace=False)
            benigns = [benigns[i] for i in idx]
        valid = threats + benigns
        rng.shuffle(valid)

    final_threat = sum(1 for e in valid if e["is_threat"] == 1)
    final_benign = sum(1 for e in valid if e["is_threat"] == 0)
    print(f"\n  ✓ Final dataset: {len(valid):,d} sequences "
          f"({final_threat:,d} threat, {final_benign:,d} benign)")

    return valid


sequences = load_dataset(
    DATASET_PATH,
