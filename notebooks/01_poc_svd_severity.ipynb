# %% Cell 8: SVD Severity Analyzer

class SVDSeverityAnalyzer:
    """Core SVD analysis for the severity benchmark."""

    def __init__(self, n_components=64):
        self.n_components = n_components
        self.svd = TruncatedSVD(n_components=n_components, random_state=42)
        self.scaler = StandardScaler()

    def fit_transform(self, E, labels, raw_labels=None):
        """Fit SVD and return low-dim projections."""
        print(f"  Scaling {E.shape[0]:,d} × {E.shape[1]} matrix...")
        E_scaled = self.scaler.fit_transform(E)

        print(f"  Running TruncatedSVD ({self.n_components} components)...")
        Z = self.svd.fit_transform(E_scaled)

        self.labels_ = labels
        self.raw_labels_ = raw_labels
        self.Z_ = Z
        self.E_scaled_ = E_scaled

        self.toxin_centroid_ = Z[labels == 1].mean(axis=0)
        self.benign_centroid_ = Z[labels == 0].mean(axis=0)

        self.threat_axis_ = self.toxin_centroid_ - self.benign_centroid_
        self.threat_axis_ /= np.linalg.norm(self.threat_axis_) + 1e-8

        return Z

    def severity_score(self, Z=None):
        if Z is None:
            Z = self.Z_
        projections = Z @ self.threat_axis_
        lo, hi = projections.min(), projections.max()
        return (projections - lo) / (hi - lo + 1e-8)

    def variance_explained(self):
        return self.svd.explained_variance_ratio_

    def component_class_loading(self, n_top=15):
        Z = self.Z_
        labels = self.labels_
        effects = []
        for k in range(min(n_top, self.n_components)):
            vals_t = Z[labels == 1, k]
            vals_b = Z[labels == 0, k]
            pooled_std = np.sqrt((vals_t.std()**2 + vals_b.std()**2) / 2) + 1e-8
            d = (vals_t.mean() - vals_b.mean()) / pooled_std
            effects.append(d)
        return np.array(effects)

    def auroc(self):
        scores = self.severity_score(self.Z_)
        return roc_auc_score(self.labels_, scores)

    def spectral_gap(self):
        sv = self.svd.singular_values_
        return sv[0] / sv[1] if len(sv) > 1 else float("inf")

    def per_class_scores(self):
        if self.raw_labels_ is None:
            return {}
        scores = self.severity_score()
        result = {}
        for cls in np.unique(self.raw_labels_):
            mask = self.raw_labels_ == cls
            result[cls] = {
                "mean": float(scores[mask].mean()),
                "std": float(scores[mask].std()),
                "n": int(mask.sum()),
            }
        return dict(sorted(result.items(), key=lambda x: -x[1]["mean"]))


print("SVDSeverityAnalyzer defined ✓")

